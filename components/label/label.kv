#:import md_icons ui.icon_definitions.md_icons

<CustomLabel>:
    text_size:
        (self.width if not self.adaptive_width else None) \
        if not self.adaptive_size else None, \
        None
    color: app.theme_cls.text_color
    disabled_color:
        app.theme_cls.text_color_dark[:3] + [.5] \
        if app.theme_cls.theme_style == "Light" \
        else app.theme_cls.text_color_light[:3] + [.3]
    canvas.before:
        Color:
            rgba: app.theme_cls.transparent_color if self.disabled else self.shadow_color
        BoxShadow:
            pos: self.pos
            size: self.size
            offset: 0, 0
            spread_radius: self.spread_radius
            border_radius: self.radius
        Color:
            rgba: self.bg_color[:3] + [.8] if self.disabled else self.bg_color
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: self.radius
        Color:
            rgba: self.line_color
        Line:
            width: self.line_width
            rounded_rectangle:
                [
                self.x,
                self.y,
                self.width,
                self.height,
                *self.radius,
                ]

<Icon>:
    size_hint: None, None
    text_size: None, None
    size: self.texture_size
    font_size: "24sp"
    text:
        ( \
        u"{}".format(md_icons[self.icon]) \
        if self.icon in md_icons else \
        "blank" \
        )

<Badge>
    font_size: "12sp"
    radius: [self.texture_size[1] / 2, ]
    pos_hint: {"center_x": 0.5, "center_y": 0.5}
    padding: "2dp"
    halign: "center"
    valign: "center"
    adaptive_size: True
    bg_color: app.theme_cls.primary_color
    -color: "white"
    pos:
        ( \
        self.parent.x + (self.parent.width - dp(5)), \
        self.parent.y + (self.parent.height - dp(5)) \
        ) \
        if self.parent else (0, 0)

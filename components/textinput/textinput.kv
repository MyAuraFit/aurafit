<CustomTextInput>
    size_hint_y: None
    write_tab: False
    height: self.minimum_height
    cursor_color: app.theme_cls.primary_color
    cursor_width: "2sp"
    multiline: False
    selection_color: app.theme_cls.primary_color[:3] + [.5]
    hint_text_color: [1.0, 0.98, 0.83, 0.5] if app.theme_cls.theme_style == "Dark" else [0.35, 0.30, 0.23, 0.5]
    canvas.before:
        Clear
        Color:
            rgba: self.shadow_color
        BoxShadow:
            pos: self.pos
            size: self.size
            offset: 0, 0
            spread_radius: -dp(5), -dp(5)
            border_radius: [*self.radius]
        Color:
            rgba: self.bg_color if self.bg_color else app.theme_cls.card_color
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: self.radius
        Color:
            rgba: self.line_color
        Line:
            width: self.line_width
            rounded_rectangle:
                [
                self.x,
                self.y,
                self.width,
                self.height,
                *self.radius,
                ]
        Color:
            rgba:
                (self.cursor_color
                if self.focus and not self._cursor_blink
                and int(self.x + self.padding[0]) <= self._cursor_visual_pos[0] <= int(self.x + self.width - self.padding[2])
                else (0, 0, 0, 0))
        Rectangle:
            pos: self._cursor_visual_pos
            size: root.cursor_width, -self._cursor_visual_height
        Color:
            rgba: self.disabled_foreground_color if self.disabled else (self.hint_text_color if not self.text else app.theme_cls.text_color)
    @mainthread
    def on_generation_success(self, result: GenerateContentResponse):
        response_content = result.getCandidates()[0].getContent()
        textures = []
        from kvdroid import activity

        cache_dir = join(activity.getCacheDir().getAbsolutePath(), "texture-cache")
        if not exists(cache_dir):
            mkdir(cache_dir)
        for part in response_content.getParts():
            if isinstance(part, ImagePart):
                from kvdroid.tools.kivytools import bitmap_to_texture

                texture = bitmap_to_texture(part.getImage())
                textures.append(texture)

                t = time.gmtime()
                timestamp = time.strftime("%b-%d-%Y_%H:%M:%S", t)
                image_path = join(cache_dir, f"my-aurafit-{timestamp}.png")
                self.image_paths.append(image_path)
                print(texture.save(image_path, flipped=False))
                print(os.listdir(cache_dir))
                print(os.listdir())

            if isinstance(part, TextPart):
                text = cast(TextPart, part).getText()
                print(text)

        print(textures)
        if not textures and self.ids.style_4.texture is None:
            self.generate_outfit.decrement()
            self.generate_outfit()
            return

        if textures and self.generate_outfit.calls_made() == 1:
            self.ids.image.texture = textures[0]
            self.ids.image.export_to_png(join(cache_dir, join(cache_dir, "outfit.png")))

        for i, tex in enumerate(textures):
            if (self.generate_outfit.calls_made() + i) > 4:
                continue
            self.ids[f"style_{self.generate_outfit.calls_made() + i}"].texture = tex

        if hasattr(self.children[0], "is_removable"):
            self.remove_widget(self.children[0])

        if len(textures) == 4:
            return

        if self.ids.style_4.texture:
            return

        self.generate_outfit()

    def on_generation_failure(self, error):
        error.printStackTrace()
        print(f"Failed to generate outfit: {error.toString()}")
        self.toast(error.toString())
        self.generate_outfit.decrement()
        self.generate_outfit()

    def download_images(self):
        from androidstorage4kivy.sharedstorage import SharedStorage

        to_be_deleted = []
        ss = SharedStorage()
        for image_path in self.image_paths:
            print(image_path, exists(image_path))
            print(ss.copy_to_shared(image_path))
        for image_path in to_be_deleted:
            os.remove(image_path)
            self.image_paths.remove(image_path)
        self.toast("Images downloaded")

    def share_images(self):
        from androidstorage4kivy.sharesheet import ShareSheet
        from kvdroid.jclass.android import Uri
        from kvdroid.jclass.java import File

        ShareSheet().share_file_list(
            [Uri().fromFile(File(image_file)) for image_file in self.image_paths]
        )
        print("Sharing")

    def on_leave(self, *args):
        for i in range(1, 5):
            self.ids[f"style_{i}"].source = ""
            self.ids[f"style_{i}"].loading_image = ""
        self.ids.image.loading_image = ""
        self.ids.image.source = ""
        if self.in_progress:
            self.cancel = True
            print("Cancelling")
        self.generate_outfit.reset()

    @property
    def in_progress(self):
        if self.generate_outfit.in_progress():
            return True
        elif self.generate_outfit.calls_made() == 4 and self.ids.style_4.source == "":
            return True
        else:
            return False

<OutfitsScreen>
    name: "outfits screen"
    BoxLayout:
        orientation: "vertical"
        CustomBoxLayout:
            padding: "20dp", "10dp", "20dp", "20dp"
            adaptive_height: True
            CustomLabel:
                text: "Outfits"
                adaptive_height: True
                font_size: "28sp"
                bold: True
                pos_hint: {"center_y": .5}
            IconButton:
                bg_color: app.theme_cls.card_color
                icon: "account"
                -radius: "10dp"
                size: "35dp", "35dp"
                font_size: "20sp"
                pos_hint: {"center_y": .5}
                shadow_color: app.theme_cls.shadow_color
                on_release: root.manager.current = "account screen"
        Divider
        RecycleView:
            id: rv
            viewclass: "Outfit"
            effect_cls: "ScrollEffect"
            scroll_distance: 0
            bar_width: 0
            do_scroll_x: False
            RecycleGridLayout:
                id: rv_box
                size_hint_y: None
                cols: 3
                height: self.minimum_height
                padding: "10dp", "10dp", "10dp", "100dp"
                spacing: "10dp"
                default_size_hint: 1, None
                default_size: 0, "200dp"
    CircularProgressIndicator:
        id: spinner
        active: False
        line_width: "1dp"
        determinate: True
        size_hint: None, None
        size: "10dp", "10dp"
        pos_hint: {"center_x": .5}
        y: "80dp"

<Outfit@TouchRippleButtonBehavior+CoverImage>
    radius: "16dp"

#:import datetime datetime.datetime
#:import LowerScrollEffect components.effects.LowerScrollEffect
#:import ScrollEffect kivy.effects.scroll.ScrollEffect
#:import StretchOverScrollStencil components.effects.StretchOverScrollStencil
#:import SharedAxisTransition components.transition.SharedAxisTransition
#:import NoTransition kivy.uix.screenmanager.NoTransition
#:import gcfh kivy.utils.get_color_from_hex
#:import Window kivy.core.window.Window
#:import shorten_text libs.shorten_text
#:set primary_color "#2962ff"
#:set icon_path "assets/fonts/materialdesignicons-webfont.ttf"

#<TouchRippleBehavior>:
#    ripple_duration_in: .7
#    ripple_duration_out: .5
#    ripple_color: app.theme_cls.card_color

<StencilBoxLayout@CustomBoxLayout+StencilBehavior>

<ButtonBoxLayout@TouchRippleButtonBehavior+CustomBoxLayout+AdaptiveBehavior>
<ToggleBoxLayout@ToggleButtonBehavior+CustomBoxLayout>
    allow_no_selection: False
    line_color: app.theme_cls.primary_color if self.active else app.theme_cls.transparent_color

<Chip@ButtonBoxLayout>
    size_hint_y: None
    height: "32dp"
    bg_color: app.theme_cls.bg_color
    line_width: 1
    radius: "6dp"
    text: ""
    adaptive_width: True
    CustomLabel:
        text: root.text
        adaptive_width: True
        halign: "center"
        bold: True
        padding: "15dp", 0
        pos_hint: {"center_y": .5}
        font_size: "14dp"

<MagicButton@CustomButton+MagicBehavior>

<TagTextInput@CustomBoxLayout>:
    adaptive_height: True
    orientation: "vertical"
    spacing: "5dp"
    tag: ""
    hint_text: ""
    text: ""
    password: False
    bold: False
    input_type: "null"
    input_filter: None
    focus: False
    font_size: "15sp"
    txt_input_bg_color: app.theme_cls.card_color
    txt_input_padding: "15dp", "18dp"
    keyboard_show_callback: lambda: None
    keyboard_hide_callback: lambda: None
    CustomLabel:
        text: root.tag
        adaptive_height: True
        markup: True
        font_size: "13sp"
        color: app.theme_cls.text_color[:3] + [.7]
    CustomTextInput:
        id: txt_input
        padding: root.txt_input_padding
        radius: "10dp"
        password: root.password
        text: root.text
        bg_color: root.txt_input_bg_color
        focus: root.focus
        font_size: root.font_size
        hint_text: root.hint_text
        input_type: root.input_type
        input_filter: root.input_filter
        on_text: root.text = self.text
        on_focus: root.focus = self.focus
        on_keyboard_show: root.keyboard_show_callback()
        on_keyboard_hide: root.keyboard_hide_callback()

<Selector>
    color: app.theme_cls.primary_color

<ScreenManager>
    canvas.before:
        Clear
    canvas.after:
        Clear

<PremiumPurchaseSheet>
    -padding: 0
    radius: 0
    RelativeLayout:
        CoverImage:
            id: image
            color: [0, 0, 0, 0] if not self.source else "white"
        IconButton:
            size: "35sp", "35sp"
            radius: self.height / 2
            icon: "close"
            bg_color: app.theme_cls.card_color[:3] + [.5]
            color: app.theme_cls.text_color_dark
            pos_hint: {"right": .9, "top": .8}
            on_release: root.dismiss()
    CustomBoxLayout:
        id: bottom
        padding: "20dp", "20dp", "20dp", dp(20) + app.navbar_height
        adaptive_height: True
        spacing: "20dp"
        orientation: "vertical"
        CustomBoxLayout:
            orientation: "vertical"
            spacing: "5dp"
            adaptive_height: True
            Benefits:
                text: "Enjoy up to 14 days free trial"
            Benefits:
                text: "Predict your farm yield without ads"
            Benefits:
                text: "Access to Crop Analytics without ads"
            Benefits:
                text: "Chat with Farmi-AI without ads"
        CustomBoxLayout:
            adaptive_height: True
            spacing: "10dp"
            ButtonBoxLayout:
                line_color: app.theme_cls.primary_color
                line_width: "2dp"
                orientation: "vertical"
                size_hint_y: None
                height: "150dp"
                radius: "10dp"
                bg_color: app.theme_cls.card_color
                disabled: spinner1.active
                on_release: root.launch_billing_flow(yearly.index)
                RelativeLayout:
                    CustomBoxLayout:
                        orientation: "vertical"
                        CustomLabel:
                            font_size: "13sp"
                            bold: True
                            text: "MOST POPULAR"
                            adaptive_height: True
                            halign: "center"
                            radius: "10dp", "10dp", 0, 0
                            padding: 0, "3.5dp"
                            color: app.theme_cls.text_color_dark
                            bg_color: app.theme_cls.primary_color
                        CustomLabel:
                            text: "14-DAY\nFREE TRIAL"
                            padding: "20dp", 0
                            bold: True
                            font_size: "16sp"
                            halign: "center"
                        CustomLabel:
                            id: yearly
                            index: 0
                            price: ""
                            text: "Then {}/year".format(self.price)
                            adaptive_height: True
                            font_size: "12sp"
                            halign: "center"
                            padding: "10dp", 0, "10dp", "20dp"
                            bold: True
                    CircularProgressIndicator:
                        id: spinner1
                        active: True
                        size_hint: None, None
                        size: "20dp", "20dp"
                        pos_hint: {"center": [.5, .5]}
                        line_width: 2
            ButtonBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "150dp"
                radius: "10dp"
                bg_color: app.theme_cls.card_color
                disabled: spinner2.active
                on_release: root.launch_billing_flow(monthly.index)
                RelativeLayout:
                    CustomBoxLayout:
                        orientation: "vertical"
                        CustomLabel:
                            text: "Monthly"
                            font_size: "14sp"
                            halign: "center"
                        CustomLabel:
                            text: "7-DAY\nFREE TRIAL"
                            padding: "20dp", 0
                            bold: True
                            font_size: "16sp"
                            halign: "center"
                        CustomLabel:
                            id: monthly
                            index: 0
                            price: ""
                            text: "Then {}/month".format(self.price)
                            font_size: "12sp"
                            halign: "center"
                            bold: True
                    CircularProgressIndicator:
                        id: spinner2
                        active: True
                        size_hint: None, None
                        size: "20dp", "20dp"
                        pos_hint: {"center": [.5, .5]}
                        line_width: 2
        CustomBoxLayout:
            adaptive_height: True
            orientation: "vertical"
            spacing: "10dp"
            MagicButton:
                id: btn
                adaptive_height: True
                padding: "30dp", "20dp"
                font_size: "18sp"
                radius: self.height / 2
                text: "Try for Free"
                pos_hint: {"center_x": .5}
                bold: True
                line_color: app.theme_cls.text_color
                pos: root.width - self.width - dp(20), "40dp"
                disabled: spinner1.active
                on_release: root.launch_billing_flow(yearly.index)
            CustomLabel:
                text: "Google play will send a reminder 2 days before your trial ends"
                font_size: "10sp"
                adaptive_height: True
                halign: "center"
                bg_color: app.theme_cls.card_color
                line_color: app.theme_cls.text_color
                line_width: 1
                padding: "10dp"
                radius: self.height / 2
            CustomLabel:
                font_size: "10sp"
                adaptive_height: True
                text:
                    "Payment will be charged to your Google Play account at the end of your trial " \
                    "or confirmation of purchase if you are not starting a trial. Subscription automatically " \
                    "renews unless it is canceled at least 24 hours before end of your trial or current period. "\
                    "Your account will be charged for renewal within 24 hours prior to the end of the current " \
                    "period. You can manage and cancel your subscriptions in settings in the google Google play "\
                    "store."

<Benefits@CustomBoxLayout>
    adaptive_height: True
    spacing: "10dp"
    text: ""
    Icon:
        icon: "check-circle"
        color: app.theme_cls.primary_color
    CustomLabel:
        text: root.text
        adaptive_height: True
        font_size: "14sp"
        pos_hint: {"center_y": .5}

<SubscribedSheet>
    -padding: "20dp", "40dp", "20dp", app.navbar_height + dp(40)
    spacing: "20dp"
    Icon:
        icon: "check"
        font_size: "50sp"
        pos_hint: {"center_x": .5}
        color: app.theme_cls.primary_color
    CustomLabel:
        adaptive_height: True
        text: "Subscription successfully"
        bold: True
        font_size: "32sp"
        halign: "center"
    CustomLabel:
        adaptive_height: True
        text: "Thank you for subscribing to Farmi-AI. You will receive email with your subscription details."
        font_size: "14sp"
        color: app.theme_cls.text_color[:3] + [.7]
        halign: "center"

<PurchaseNoticeSheet>
    IconButton:
        radius: self.height / 2
        icon: "close"
        pos_hint: {"right": 1}
        on_release: root.go_back_home()
    CustomLabel:
        adaptive_height: True
        font_size: "32sp"
        text: "Notice"
        bold: True
        halign: "center"
    CustomLabel:
        adaptive_height: True
        font_size: "14sp"
        text:
            "You are not subscribed to Farmi-AI. For you to continue, " \
            "you either purchase a subscription or watch an ads video every 5 minutes. "\
            "We recommend you purchase a subscription to enjoy all the features of " \
            "Farmi-AI with up to 14 days free trial. You can manage and cancel your " \
            "subscriptions in settings in the google Google play store."
        color: app.theme_cls.text_color[:3] + [.7]
        halign: "center"
    CustomButton:
        size_hint_y: None
        height: "45dp"
        radius: self.height / 2
        text: f"Subscribe [font={icon_path}][size={int(sp(24))}]\U000F01A5[/size][/font]"
        markup: True
        bold: True
        on_release: root.subscribe()
    CustomButton:
        size_hint_y: None
        height: "45dp"
        radius: self.height / 2
        text: "Watch ADS"
        color: app.theme_cls.text_color
        bold: True
        -bg_color: app.theme_cls.card_color
        disabled: spinner.active
        on_release: root.watch_ads()
        CircularProgressIndicator:
            id: spinner
            active: False
            size: "20dp", "20dp"
            pos: self.parent.width - dp(20), self.parent.y + ((self.parent.height / 2) - (self.height / 2))
            line_width: 2